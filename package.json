{
  "name": "breakerbot",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node src/index.js",
    "start:api": "node src/api/server.js",
    "dev": "concurrently --names \"BOT,API\" --prefix-colors \"green,blue\" \"npm run start\" \"npm run start:api\"",
    "startwapi": "concurrently --names \"BOT,API\" --prefix-colors \"green,blue\" \"npm run start\" \"npm run start:api\"",
    "server": "pm2 start src/index.js --name BreakerBot --env production && pm2 start src/api/server.js --name BreakerBotAPI --env production",
    "stop": "pm2 stop BreakerBot BreakerBotAPI",
    "restart": "pm2 restart BreakerBot BreakerBotAPI",
    "logs": "pm2 logs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@whiskeysockets/baileys": "github:WhiskeySockets/Baileys#android-browser",
    "concurrently": "^9.1.2",
    "dotenv": "^17.3.1",
    "pm2": "^6.0.5",
    "qrcode-terminal": "^0.12.0"
  }
}
